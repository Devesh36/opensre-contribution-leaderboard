# GitHub personal access token with public_repo read access
GITHUB_TOKEN=
# or
# GH_TOKEN=

# Vercel Blob read/write token (Project → Storage → Blob)
BLOB_READ_WRITE_TOKEN=

# Secret used to authenticate cron refresh requests
CRON_SECRET=

# Optional public blob URL after first refresh
# LEADERBOARD_BLOB_URL=
# GITHUB_REPOSITORY=Tracer-Cloud/opensre
# LEADERBOARD_BLOB_PATH=leaderboard/snapshot.json
